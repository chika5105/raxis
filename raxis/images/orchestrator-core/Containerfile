# RAXIS canonical Orchestrator image — Containerfile.
#
# Normative reference: planner-harness.md §10.5 (image manifest) and
# §14.4 (image-build pipeline).
#
# The Orchestrator image is exactly large enough to perform 3-way
# semantic git merges with bash + git + edit_file, and nothing more.
# Per `planner-harness.md §10.5`:
#
#  - `raxis-planner-orchestrator` (PID 1, foreground bash only,
#    custom-tool dispatch excluded, SubmitReview / SingleCommit
#    excluded at link time)
#  - `bash` ≥ 5.0 (foreground only — bg_* paths excluded by build)
#  - `git` ≥ 2.30 (semantic conflict resolution via `git merge`,
#    `git diff`, `edit_file`, `IntegrationMerge`)
#  - `ripgrep` (statically linked)
#  - Standard POSIX coreutils for `git`'s helper invocations
#  - Minimal CA-certificates bundle (no network exposed; git's
#    sanity checks expect one)
#
# Notably absent: language runtimes, compilers, package managers,
# LSP servers, network utilities, editors, build systems.

FROM debian:bookworm-slim AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# Install required tools (bash, git, ripgrep, coreutils are included in base or explicitly added)
RUN apt-get update && apt-get install --no-install-recommends -y \
    bash \
    git \
    ripgrep \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Enforce the strict binary exclusion list (planner-harness.md §10.5)
# Git pulls in perl, but the orchestrator does not need it for 3-way merges.
RUN rm -f \
    /usr/bin/python3 \
    /usr/bin/node \
    /usr/bin/ruby \
    /usr/bin/perl \
    /usr/bin/lua \
    /usr/bin/rustc \
    /usr/bin/gcc \
    /usr/bin/clang \
    /usr/bin/tsc \
    /usr/bin/go \
    /usr/bin/npm \
    /usr/bin/cargo \
    /usr/bin/pip \
    /usr/bin/gem \
    /usr/bin/curl \
    /usr/bin/wget \
    /usr/bin/ssh \
    /usr/bin/nc \
    /usr/bin/vi \
    /usr/bin/nano \
    /usr/bin/emacs \
    /usr/bin/less \
    /usr/bin/make \
    /usr/bin/bazel \
    /usr/bin/meson \
    /usr/bin/ninja || true
