# RAXIS Executor starter image — Containerfile.
#
# Normative reference: planner-harness.md §10.6 (image manifest) and
# §14.4 (image-build pipeline).
#
# Distribution path:
#   $RAXIS_INSTALL_DIR/images/raxis-executor-starter-<kernel_version>.img
#
# This image is **opt-in**: operators select it via
# `policy.toml [default_executor_image]`. The kernel does not require
# this image to exist; operators who pin their own digest-pinned
# Executor image never use the starter.
#
# Generalist tooling consistent with planner-harness.md §10.6:
#  - Node 20 LTS
#  - Python 3.11
#  - Rust stable
#  - Go 1.22
#  - git ≥ 2.30, GitHub CLI
#  - Modern Unix tooling: rg, fd, jq, yq
#  - HTTP clients: curl, wget (gated by tproxy at the network layer)
#  - Build toolchain: make, gcc, g++, clang, ld, ar
#
# The image ships with an empty egress allowlist; tasks using it must
# declare `allowed_egress = [...]` to reach the network. Custom tools
# remain opt-in.

FROM debian:bookworm-slim AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# Pinned versions are tracked via apt's package-version locks; CI
# reruns the determinism check against the pinned digests in
# `manifest.toml`.

RUN apt-get update && apt-get install --no-install-recommends -y \
    bash \
    build-essential \
    ca-certificates \
    coreutils \
    curl \
    findutils \
    git \
    gnupg \
    grep \
    iproute2 \
    jq \
    less \
    make \
    netcat-openbsd \
    nftables \
    procps \
    sed \
    tar \
    unzip \
    wget \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Path A3 universal-airgap (`specs/v2/airgap-architecture.md §6`)
# requires native `nft` inside the guest to install the `nat OUTPUT`
# REDIRECT chain at PID-1 setup time. We do not use the iptables
# compatibility frontends: the canonical guest kernel is validated
# for built-in nftables NAT/REDIRECT support, and native nftables
# avoids xtables extension drift. `iproute2` is pulled in for the
# cred-proxy loopback-forwarder + the A3 stub if a future operator
# wants to debug the chain interactively.
#
# These packages add ~5 MB to the canonical executor rootfs and
# are unconditionally enabled because the kernel-side `EgressTier`
# selection is the cgroup that decides whether they are
# load-bearing.

# Node 20 LTS via NodeSource.
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install --no-install-recommends -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Pre-baked JavaScript / TypeScript lint toolchain
# (`INV-EXECUTOR-IMAGE-LINT-TOOLCHAIN-JS-01`).
#
# Sibling of the Python lint-toolchain block below: the
# realistic-scenario `lint-runner-js` task (iter55 split,
# kernel/tests/extended_e2e_support/plan_realistic.rs::TASK_LINT_RUNNER_JS)
# runs `npx --no-install eslint --max-warnings 0 . && npx
# --no-install prettier --check . && npx --no-install tsc
# --noEmit` against `live-e2e/seed/repo/rich-multilang-001/ts-pkg/`,
# whose `package.json` lists `eslint`, `prettier`, `tsx`,
# `typescript`, and `@typescript-eslint/parser` as devDependencies.
# The seed materializer
# (`scripts/materialize_seed.sh`) does NOT pre-fetch a
# `ts-pkg/node_modules/` (every node_modules ships ~thousands of
# files; baking it into the seed git history would dwarf the
# fixture). The executor VM also ships with no egress allowlist
# by default — `npx --no-install` therefore needs to resolve
# `eslint` / `prettier` / `tsc` from a path the VM image
# pre-populates, not from `registry.npmjs.org`.
#
# npx 7+ resolves binaries in this order:
#   1. `./node_modules/.bin/<cmd>`
#   2. walking up parents
#   3. `npm root -g` global node_modules
#   4. `$PATH` (only when above miss)
# Installing via `npm install -g` puts the packages at
# `/usr/lib/node_modules/<pkg>` with `.bin` symlinks in
# `/usr/bin/`, so step 3 matches and `--no-install` succeeds.
#
# Pin policy mirrors the Python block: explicit semver pins,
# `latest` forbidden. The chosen versions satisfy the seed
# `package.json`'s `^` ranges (eslint ^9.0.0, prettier ^3.2.5,
# typescript ^5.4.0, tsx ^4.7.0, @types/node ^20.11.0) AND are
# stable November-2024 / late-2024 releases so the rule surface
# does not drift under a transitive bump. The parser is required
# because ESLint 9's stock parser cannot parse TypeScript syntax.
RUN npm install -g --no-audit --no-fund --loglevel=error \
        "eslint@9.15.0" \
        "prettier@3.3.3" \
        "typescript@5.6.3" \
        "tsx@4.19.2" \
        "@types/node@20.17.6" \
        "@typescript-eslint/parser@8.15.0"

# Python 3.11 (Debian bookworm ships 3.11 in the default repo).
RUN apt-get update && apt-get install --no-install-recommends -y \
    python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Pinned Python client libraries used by the operator's stock
# service-integrity scripts (see
# `raxis/live-e2e/seed/scripts/transparent_proxy/requirements.txt`).
# Versions MUST stay in lock-step with that requirements file so the
# realistic-scenario transparent-proxy task does not silently drift
# under a transitive library bump.
#
#   * psycopg2-binary - Postgres (DBAPI 2.0; `DATABASE_URL`)
#   * pymongo        - MongoDB  (`MONGO_URL`)
#   * redis          - Redis    (`REDIS_URL`)
#   * PyMySQL        - MySQL    (`MYSQL_URL`; opt-in)
#   * pymssql        - MSSQL    (`MSSQL_URL`; opt-in)
#
# `--break-system-packages` is required because Debian bookworm
# treats the system Python as a PEP-668 "externally managed
# environment". The starter image is a single-tenant VM rootfs;
# there is no system package manager racing against pip, so the
# concern PEP-668 guards against does not apply here. We use
# `--no-cache-dir` so the layer stays minimal.
RUN pip3 install --no-cache-dir --break-system-packages \
        "psycopg2-binary==2.9.10" \
        "pymongo==4.10.1" \
        "redis==5.2.1" \
        "PyMySQL==1.1.1" \
        "pymssql==2.3.2"

# Pre-baked Python lint toolchain
# (`INV-EXECUTOR-IMAGE-LINT-TOOLCHAIN-PYTHON-01`).
#
# The realistic-scenario `lint-runner-python` task (iter55 split,
# kernel/tests/extended_e2e_support/plan_realistic.rs::TASK_LINT_RUNNER_PYTHON)
# runs `python -m ruff check . && python -m ruff format --check .`
# against `live-e2e/seed/repo/rich-multilang-001/py-pkg/`, whose
# `ruff.toml` selects the `E,F,W,I,B,UP,SIM` rule families. The
# executor VM ships with **no egress allowlist by default**
# (`§10.6` egress posture; `INV-VM-EGRESS-01`), so the task cannot
# `pip install ruff` at runtime — the lint capture has to find
# `ruff` already importable from system site-packages.
#
# This mirrors how `cargo fmt --check` + `cargo clippy` already
# work for the parallel `lint-runner-rust` task: the Rust
# toolchain is rustup-installed earlier in this Containerfile and
# the seed crate's `[dependencies]` is empty, so `cargo` runs
# against the pre-baked binaries without ever needing network
# access. The Python side reaches the same shape by pinning ruff
# at image-bake time into system site-packages; `python -m ruff`
# from the task body then resolves through the same import path
# the seed `ruff.toml` already targets.
#
# Pin policy: NEVER `latest`; the version bump is an explicit,
# auditable diff against this file. The choice of 0.7.4
# (released 2024-11-07) satisfies the seed's
# `target-version = "py310"` + `E,F,W,I,B,UP,SIM` rule selection
# without depending on bleeding-edge rule churn. Bumping requires
# re-running the realistic-scenario witness to confirm the seed's
# canonical `F401` defect (unused `import os`) still surfaces
# verbatim.
RUN pip3 install --no-cache-dir --break-system-packages \
        "ruff==0.7.4"

# Rust stable via rustup. The explicit envs are mirrored by the
# executor PID-1 defaults so rustup shims resolve the baked toolchain
# even when a substrate boots with HOME=/.
ENV CARGO_HOME=/root/.cargo
ENV RUSTUP_HOME=/root/.rustup
ENV RUSTUP_TOOLCHAIN=stable
ENV PATH=/root/.cargo/bin:$PATH
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable \
    && rustup default stable \
    && rustup component add rustfmt clippy

# Go 1.22 — fetch the upstream tarball matching the build platform.
# `dpkg --print-architecture` returns the Debian arch identifier
# (`amd64` / `arm64` / ...), which lines up with Google's Go release
# filenames (`go1.22.0.linux-amd64.tar.gz`,
# `go1.22.0.linux-arm64.tar.gz`). Hardcoding `amd64` would break the
# arm64 bake (Apple Silicon dev hosts + arm64 CI workers) with a
# silent `tar: This does not look like a tar archive` past a
# 404 HTML body that curl happily streamed in.
RUN GOARCH="$(dpkg --print-architecture)" \
    && curl -fsSL "https://go.dev/dl/go1.22.0.linux-${GOARCH}.tar.gz" \
        | tar -C /usr/local -xzf -
ENV PATH=/usr/local/go/bin:$PATH

# GitHub CLI — pin the apt source's `arch=` to the build platform so
# `apt-get install gh` resolves the matching binary. NodeSource +
# rustup + Go each handle arch internally; the GitHub CLI Debian
# repo gates by `arch=` so an `arch=amd64` line on an arm64 builder
# silently surfaces an empty package list and `Unable to locate
# package gh`.
RUN GH_ARCH="$(dpkg --print-architecture)" \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/trusted.gpg.d/githubcli.gpg \
    && echo "deb [arch=${GH_ARCH}] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install --no-install-recommends -y gh \
    && rm -rf /var/lib/apt/lists/*

# rg + fd via cargo (pinned to their stable versions).
RUN cargo install ripgrep fd-find

# Note: `raxis-planner-executor` (the role's PID-1 entry point) is
# **NOT** copied in by this Containerfile. The planner binary is
# overlaid onto the baked rootfs by `cargo xtask images bake --role
# executor-starter` after this image is exported. Keeping the two
# concerns separate (this file = base OS tooling; Rust binary =
# planner entry point) lets the Containerfile bake be cached across
# many planner-binary rebuilds and matches the V2 manifest-trust
# pipeline (the manifest's `image_artefact_sha256` covers the
# merged rootfs+planner tree).
#
# Operator command:
#   cargo xtask images bake --role executor-starter
#        -> preflight, build/export this rootfs, cross-compile the
#           planner binary, and pack/sign the initramfs at
#           $RAXIS_INSTALL_DIR/images/raxis-executor-starter-<kver>.{img,manifest.toml}.
