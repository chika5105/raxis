# RAXIS Executor starter image — Containerfile.
#
# Normative reference: planner-harness.md §10.6 (image manifest) and
# §14.4 (image-build pipeline).
#
# Distribution path:
#   $RAXIS_INSTALL_DIR/images/raxis-executor-starter-<kernel_version>.img
#
# This image is **opt-in**: operators select it via
# `policy.toml [default_executor_image]`. The kernel does not require
# this image to exist; operators who pin their own digest-pinned
# Executor image never use the starter.
#
# Generalist tooling consistent with planner-harness.md §10.6:
#  - Node 20 LTS
#  - Python 3.11
#  - Rust stable
#  - Go 1.22
#  - git ≥ 2.30, GitHub CLI
#  - Modern Unix tooling: rg, fd, jq, yq
#  - HTTP clients: curl, wget (gated by tproxy at the network layer)
#  - Build toolchain: make, gcc, g++, clang, ld, ar
#
# The image ships with an empty egress allowlist; tasks using it must
# declare `allowed_egress = [...]` to reach the network. Custom tools
# remain opt-in.

FROM debian:bookworm-slim AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# Pinned versions are tracked via apt's package-version locks; CI
# reruns the determinism check against the pinned digests in
# `manifest.toml`.

RUN apt-get update && apt-get install --no-install-recommends -y \
    bash \
    coreutils \
    curl \
    findutils \
    git \
    gnupg \
    grep \
    jq \
    less \
    make \
    netcat-openbsd \
    procps \
    sed \
    tar \
    unzip \
    wget \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Node 20 LTS via NodeSource.
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install --no-install-recommends -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Python 3.11 (Debian bookworm ships 3.11 in the default repo).
RUN apt-get update && apt-get install --no-install-recommends -y \
    python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Pinned Python client libraries used by the operator's stock
# service-integrity scripts (see
# `raxis/live-e2e/seed/scripts/transparent_proxy/requirements.txt`).
# Versions MUST stay in lock-step with that requirements file so the
# realistic-scenario transparent-proxy task does not silently drift
# under a transitive library bump.
#
#   * psycopg2-binary - Postgres (DBAPI 2.0; `DATABASE_URL`)
#   * pymongo        - MongoDB  (`MONGO_URL`)
#   * redis          - Redis    (`REDIS_URL`)
#   * PyMySQL        - MySQL    (`MYSQL_URL`; opt-in)
#   * pymssql        - MSSQL    (`MSSQL_URL`; opt-in)
#
# `--break-system-packages` is required because Debian bookworm
# treats the system Python as a PEP-668 "externally managed
# environment". The starter image is a single-tenant VM rootfs;
# there is no system package manager racing against pip, so the
# concern PEP-668 guards against does not apply here. We use
# `--no-cache-dir` so the layer stays minimal.
RUN pip3 install --no-cache-dir --break-system-packages \
        "psycopg2-binary==2.9.10" \
        "pymongo==4.10.1" \
        "redis==5.2.1" \
        "PyMySQL==1.1.1" \
        "pymssql==2.3.2"

# Rust stable via rustup.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
ENV PATH=/root/.cargo/bin:$PATH

# Go 1.22.
RUN curl -fsSL https://go.dev/dl/go1.22.0.linux-amd64.tar.gz | tar -C /usr/local -xzf -
ENV PATH=/usr/local/go/bin:$PATH

# GitHub CLI.
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/trusted.gpg.d/githubcli.gpg \
    && echo "deb [arch=amd64] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install --no-install-recommends -y gh \
    && rm -rf /var/lib/apt/lists/*

# rg + fd via cargo (pinned to their stable versions).
RUN cargo install ripgrep fd-find

# Note: `raxis-planner-executor` (the role's PID-1 entry point) is
# **NOT** copied in by this Containerfile. The planner binary is
# overlaid onto the baked rootfs by `cargo xtask images dev-stage
# --role executor-starter` after this image is exported. Keeping the
# two concerns separate (this file = base OS tooling; dev-stage =
# planner binary) lets the Containerfile bake be cached across many
# planner-binary rebuilds and matches the V2 manifest-trust pipeline
# (the manifest's `image_artefact_sha256` covers the merged
# rootfs+planner tree, computed at `build-all` time).
#
# Build pipeline:
#   1. cargo xtask images bake-rootfs  --role executor-starter
#        → docker/podman/buildah build of THIS Containerfile;
#          export filesystem to images/executor-starter/rootfs/.
#   2. cargo xtask images dev-stage    --role executor-starter
#        → cross-compile raxis-planner-executor; overlay at
#          images/executor-starter/rootfs/usr/local/bin/raxis-executor;
#          create /init symlink.
#   3. cargo xtask images build-all    [--role executor-starter]
#        → pack into signed cpio.gz initramfs at
#          $RAXIS_INSTALL_DIR/images/raxis-executor-starter-<kver>.{img,manifest.toml}.
