# RAXIS guest-kernel config fragment for Path A3 egress.
#
# Merge this into the Linux guest kernel .config before building
# vmlinux, then stage both artifacts with:
#
#   cargo xtask images dev-kernel --from-file <vmlinux> --config <.config> --force
#
# These options must be built in (=y), not modules (=m), because the
# canonical initramfs does not ship a module tree or modprobe path.

CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NF_TABLES=y
# A3's runtime ruleset uses the IPv4 family (`table ip`). Keep INET
# enabled in the reference fragment for kernels/operators that want it,
# but xtask validation only relies on CONFIG_NF_TABLES_IPV4.
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REDIR=y
# Older kernels expose base NAT-chain support as its own Kconfig
# symbol. Newer kernels may fold nft_chain_nat.o under CONFIG_NFT_NAT;
# xtask validation accepts either shape.
CONFIG_NFT_CHAIN_NAT=y

# Useful for offline validation with `scripts/extract-ikconfig` and
# for xtask's embedded-config validation fallback.
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
