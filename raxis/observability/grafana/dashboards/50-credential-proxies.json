{
  "title": "raxis | 50 Credential proxies",
  "uid": "raxis-50-credproxies",
  "tags": ["raxis", "credential-proxy"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Connection p95 (ms) by service",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le) (rate(raxis_credential_proxy_connection_duration_milliseconds_bucket[5m])))", "legendFormat": "{{service}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Statement p95 (ms) by service / operation",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, operation, le) (rate(raxis_credential_proxy_statement_duration_milliseconds_bucket[5m])))", "legendFormat": "{{service}} {{operation}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Bytes / sec by service / direction",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (service, direction) (rate(raxis_credential_proxy_bytes_total[1m]))", "legendFormat": "{{service}} {{direction}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Policy blocks / sec by service / reason",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (service, reason) (rate(raxis_credential_proxy_policy_block_total[1m]))", "legendFormat": "{{service}} {{reason}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    }
  ]
}
