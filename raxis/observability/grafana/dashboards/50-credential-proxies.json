{
  "title": "raxis | 50 Credential proxies",
  "uid": "raxis-50-credproxies",
  "tags": ["raxis", "credential-proxy"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Successful connection p95 (ms) by service",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le) (sum_over_time(raxis_credential_proxy_connection_duration_milliseconds_bucket{outcome=\"ok\"}[$__range])))", "legendFormat": "{{service}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Statement p95 (ms) by service / operation, selected range",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, operation, le) (sum_over_time(raxis_credential_proxy_statement_duration_milliseconds_bucket[$__range])))", "legendFormat": "{{service}} {{operation}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Bytes by service / direction, selected range",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (service, direction) (sum_over_time(raxis_credential_proxy_bytes_total[$__range]))", "legendFormat": "{{service}} {{direction}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Policy blocks by service / reason, selected range",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (service, reason) (sum_over_time(raxis_credential_proxy_policy_block_total[$__range]))", "legendFormat": "{{service}} {{reason}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Connection attempts by service / outcome, selected range",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        { "expr": "sum by (service, outcome) (sum_over_time(raxis_credential_proxy_connection_total[$__range]))", "legendFormat": "{{service}} {{outcome}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "stacking": { "mode": "normal", "group": "A" }, "fillOpacity": 25 } }, "overrides": [] }
    }
  ]
}
