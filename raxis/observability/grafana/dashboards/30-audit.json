{
  "title": "raxis | 30 Audit chain",
  "uid": "raxis-30-audit",
  "tags": ["raxis", "audit"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Chain length",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "targets": [{ "expr": "max(raxis_audit_chain_length)", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending unconfirmed",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "targets": [{ "expr": "max(raxis_audit_chain_lag)", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "fsync failures (5m)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "targets": [{ "expr": "sum(increase(raxis_audit_fsync_failure_total[5m]))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Append latency p50/p95/p99 (ms)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(raxis_audit_event_append_duration_milliseconds_bucket[5m])))", "legendFormat": "p50", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(raxis_audit_event_append_duration_milliseconds_bucket[5m])))", "legendFormat": "p95", "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(raxis_audit_event_append_duration_milliseconds_bucket[5m])))", "legendFormat": "p99", "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Confirmation latency p95 (Phase-B paired writes, ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (kind, le) (rate(raxis_audit_event_confirmed_duration_milliseconds_bucket[5m])))", "legendFormat": "{{kind}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Append rate by kind",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "targets": [{ "expr": "sum by (kind) (rate(raxis_audit_event_append_total[1m]))", "legendFormat": "{{kind}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    }
  ]
}
