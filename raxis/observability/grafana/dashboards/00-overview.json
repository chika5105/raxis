{
  "title": "raxis | 00 Overview",
  "uid": "raxis-00-overview",
  "tags": ["raxis", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active sessions",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(last_over_time(raxis_session_active[$__range]))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 16 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "VM cold-boot p50 (ms, selected range)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (sum_over_time(raxis_isolation_spawn_cold_boot_duration_milliseconds_bucket[$__range])))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 350 }, { "color": "red", "value": 600 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "VM cold-boot p95 (ms, selected range)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (sum_over_time(raxis_isolation_spawn_cold_boot_duration_milliseconds_bucket[$__range])))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 600 }, { "color": "red", "value": 1000 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Audit chain length",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "max(max_over_time(raxis_audit_chain_length[$__range]))", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Spawn events by outcome (selected range)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (outcome) (sum_over_time(raxis_isolation_spawn_total[$__range]))", "legendFormat": "{{outcome}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Intent admission p50/p95/p99 (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (sum_over_time(raxis_intent_admission_duration_milliseconds_bucket[$__range])))", "legendFormat": "p50", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.95, sum by (le) (sum_over_time(raxis_intent_admission_duration_milliseconds_bucket[$__range])))", "legendFormat": "p95", "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.99, sum by (le) (sum_over_time(raxis_intent_admission_duration_milliseconds_bucket[$__range])))", "legendFormat": "p99", "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Audit append events (selected range)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (event_kind) (sum_over_time(raxis_audit_event_append_total[$__range]))", "legendFormat": "{{event_kind}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Observability frames dropped (per reason)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (drop_reason) (sum_over_time(raxis_observability_dropped_total[$__range]))", "legendFormat": "{{drop_reason}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Self-healing supervisor",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Kernel respawn events by trigger (selected range)",
      "description": "raxis.kernel.respawn.total — one increment per supervisor-driven kernel respawn observed at boot. trigger ∈ { deadlock, sigsegv, sigabrt, exit_70, other }; closed lexicon per INV-OBS-KERNEL-RESPAWN-COVERAGE-01.",
      "gridPos": { "x": 0, "y": 21, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum by (trigger) (sum_over_time(raxis_kernel_respawn_total[$__range]))", "legendFormat": "{{trigger}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Kernel respawn duration p50/p95/p99 (ms, selected range)",
      "description": "raxis.kernel.respawn.duration — wall-clock from supervisor restart-decision to kernel-up-and-rehydrated. Wide histogram bucket spread (10ms → 5min) per the kernel-respawn slow-operation profile.",
      "gridPos": { "x": 8, "y": 21, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (sum_over_time(raxis_kernel_respawn_duration_milliseconds_bucket[$__range])))", "legendFormat": "p50", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.95, sum by (le) (sum_over_time(raxis_kernel_respawn_duration_milliseconds_bucket[$__range])))", "legendFormat": "p95", "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.99, sum by (le) (sum_over_time(raxis_kernel_respawn_duration_milliseconds_bucket[$__range])))", "legendFormat": "p99", "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Supervisor refused-restart events by reason (selected range)",
      "description": "raxis.supervisor.refused_restart.total — kernel observed a Halted sentinel at boot (operator manually bypassed the supervisor). reason ∈ { circuit_open, operator_stop, operator_stop_forced, supervisor_gone, other }.",
      "gridPos": { "x": 16, "y": 21, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum by (reason) (sum_over_time(raxis_supervisor_refused_restart_total[$__range]))", "legendFormat": "{{reason}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    }
  ]
}
