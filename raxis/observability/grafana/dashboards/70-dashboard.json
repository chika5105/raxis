{
  "title": "raxis | 70 Operator dashboard HTTP/SSE",
  "uid": "raxis-70-dashboard",
  "tags": ["raxis", "dashboard"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request p95 (ms) by route",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (route, le) (sum_over_time(raxis_dashboard_http_request_duration_milliseconds_bucket[$__range])))", "legendFormat": "{{route}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP requests, selected range by route / status",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (route, http_status) (sum_over_time(raxis_dashboard_http_request_duration_milliseconds_count[$__range]))", "legendFormat": "{{route}} {{http_status}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Active SSE connections by route",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (route) (last_over_time(raxis_dashboard_sse_connection_active[$__range]))", "legendFormat": "{{route}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "SSE backpressure lag p95 (ms)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (route, le) (sum_over_time(raxis_dashboard_sse_lag_duration_milliseconds_bucket[$__range])))", "legendFormat": "{{route}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    }
  ]
}
