{
  "title": "raxis | 20 Lifecycle / Sessions / Initiatives",
  "uid": "raxis-20-lifecycle",
  "tags": ["raxis", "lifecycle"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Active sessions by role",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (role) (raxis_session_active)", "legendFormat": "{{role}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Lifecycle transitions / sec",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (to_state) (rate(raxis_session_lifecycle_transition_total[1m]))", "legendFormat": "to {{to_state}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Session duration p95 (ms) by agent_type",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (agent_type, le) (rate(raxis_session_duration_milliseconds_bucket[5m])))", "legendFormat": "{{agent_type}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Initiative duration p95 (ms) by class",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (initiative_class, le) (rate(raxis_initiative_duration_milliseconds_bucket[5m])))", "legendFormat": "{{initiative_class}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Tasks in flight (per initiative class)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        { "expr": "sum by (initiative_class) (raxis_initiative_task_in_flight)", "legendFormat": "{{initiative_class}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ]
}
