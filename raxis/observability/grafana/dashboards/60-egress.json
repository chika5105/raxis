{
  "title": "raxis | 60 Egress / Gateway",
  "uid": "raxis-60-egress",
  "tags": ["raxis", "egress", "gateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Allowlist check p95 (ms)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(raxis_egress_allowlist_check_duration_milliseconds_bucket[5m])))", "legendFormat": "p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Blocked egress / sec by reason",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (reason) (rate(raxis_egress_allowlist_block_total[1m]))", "legendFormat": "{{reason}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Gateway upstream p95 (ms) by provider",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 9 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(raxis_gateway_upstream_duration_milliseconds_bucket[5m])))", "legendFormat": "{{provider}} p95", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Gateway fetch rate (req/s) by status_code",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 8 },
      "targets": [
        { "expr": "sum by (status_code) (rate(raxis_gateway_fetch_total[1m]))", "legendFormat": "{{status_code}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    }
  ]
}
