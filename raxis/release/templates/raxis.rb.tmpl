  homepage "https://raxis.io"
  version  "@@RAXIS_VERSION@@"
  license  "SSPL-1.0"

  bottle do
    root_url "@@RAXIS_BOTTLE_ROOT_URL@@"
    sha256 cellar: :any_skip_relocation, arm64_tahoe:    "@@RAXIS_BOTTLE_DARWIN_ARM64_TAHOE_SHA256@@"
    sha256 cellar: :any_skip_relocation, tahoe:          "@@RAXIS_BOTTLE_DARWIN_X86_64_TAHOE_SHA256@@"
    sha256 cellar: :any_skip_relocation, arm64_sequoia:  "@@RAXIS_BOTTLE_DARWIN_ARM64_SEQUOIA_SHA256@@"
    sha256 cellar: :any_skip_relocation, sequoia:        "@@RAXIS_BOTTLE_DARWIN_X86_64_SEQUOIA_SHA256@@"
    sha256 cellar: :any_skip_relocation, arm64_sonoma:   "@@RAXIS_BOTTLE_DARWIN_ARM64_SONOMA_SHA256@@"
    sha256 cellar: :any_skip_relocation, sonoma:         "@@RAXIS_BOTTLE_DARWIN_X86_64_SONOMA_SHA256@@"
    sha256 cellar: :any_skip_relocation, arm64_linux:    "@@RAXIS_BOTTLE_LINUX_ARM64_SHA256@@"
    sha256 cellar: :any_skip_relocation, x86_64_linux:   "@@RAXIS_BOTTLE_LINUX_X86_64_SHA256@@"
  end

  on_macos do
    on_arm do
      url "@@RAXIS_DARWIN_ARM64_URL@@"
      sha256 "@@RAXIS_DARWIN_ARM64_SHA256@@"
