# --- raxis-site environment ---
#
# Pick ONE of the two docs sources. The site builds either way; if neither is
# set and `vendor/raxis-docs/` already exists locally, the previous mirror is
# reused. If nothing exists, the site builds with an empty docs index.

# Option A — local checkout (preferred for development).
# Path is resolved relative to the repo root (where package.json lives).
RAXIS_REPO_PATH=../raxis

# Option B — public git URL (preferred for Vercel CI builds).
# RAXIS_REPO_URL=https://github.com/chika5105/raxis.git

# Optional production runtime docs source. This uses anonymous GitHub API calls
# against the public repository. No GitHub token is supported or required.
# RAXIS_GITHUB_REPO=chika5105/raxis
# RAXIS_GITHUB_BRANCH=main
# RAXIS_GITHUB_PREFIX=raxis
