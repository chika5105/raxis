{
  "name": "raxis-site",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing site and live documentation browser for the RAXIS paradigm.",
  "scripts": {
    "predev": "node scripts/sync-docs.mjs && node scripts/build-search-index.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/sync-docs.mjs && node scripts/build-search-index.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "sync-docs": "node scripts/sync-docs.mjs",
    "build-search": "node scripts/build-search-index.mjs"
  },
  "dependencies": {
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "gray-matter": "^4.0.3",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-rehype": "^11.1.1",
    "rehype-slug": "^6.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "shiki": "^1.22.2",
    "unified": "^11.0.5",
    "minisearch": "^7.1.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
